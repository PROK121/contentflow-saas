# Nest API: серверные fetch в RSC и destination для прокси /v1 → API
API_URL=http://localhost:3000

# Тот же секрет, что JWT_SECRET в api/.env (middleware проверяет cookie cf_session)
JWT_SECRET=change-me-in-production-use-long-random-string

# Опционально: UUID пользователя (как в seed) — включает фильтр «Только мои» на /deals
# NEXT_PUBLIC_PLATFORM_USER_ID=00000000-0000-4000-8000-000000000099
