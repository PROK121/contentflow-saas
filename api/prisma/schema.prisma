// ContentFlow — ядро БД (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationType {
  client
  rights_holder
  internal
}

enum UserRole {
  admin
  manager
  rights_owner
  client
}

enum DealStage {
  lead
  negotiation
  contract
  paid
}

/// Продажа — лицензирование контента контрагенту (клиент). Покупка — приобретение прав у контрагента.
enum DealKind {
  sale
  purchase
}

enum AssetType {
  video
  series
  animated_series
  animated_film
  anime_series
  anime_film
  concert_show
}

enum CatalogItemStatus {
  draft
  active
  archived
}

enum Platform {
  TV
  OTT
  Web
  YouTube
  VOD
  ShipIfec
  PublicRights
}

enum Exclusivity {
  exclusive
  co_exclusive
  non_exclusive
  sole
}

enum ContractStatus {
  draft
  sent
  signed
  expired
}

enum PaymentDirection {
  inbound
  outbound
}

enum PaymentStatus {
  pending
  partially_paid
  paid
  overdue
  cancelled
}

enum RoyaltyModel {
  fixed
  percent
}

enum RoyaltyBase {
  gross
  net
  collections
}

enum TaskType {
  contract_expiry
  payment_due
  renewal
  custom
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  low
  medium
  high
}

enum DealActivityKind {
  comment
  system
  file
}

model Organization {
  id         String           @id @default(uuid())
  legalName  String
  country    String
  taxId      String?
  isResident Boolean          @default(false)
  type       OrganizationType
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  users                User[]
  catalogItemsAsHolder CatalogItem[] @relation("RightsHolder")
  dealsAsBuyer         Deal[]        @relation("BuyerOrg")
  taxProfiles          TaxProfile[]
  royaltyLines         RoyaltyLine[]
  payouts              Payout[]
}

model User {
  id             String    @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  email          String    @unique
  /// Bcrypt-хеш пароля; null — вход по паролю недоступен.
  passwordHash   String?
  displayName    String?
  role           UserRole
  locale         String    @default("ru")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  ownedDeals     Deal[]         @relation("DealOwner")
  tasks          Task[]
  taskComments   TaskComment[]
  dealActivities DealActivity[]
}

model CatalogItem {
  id                String            @id @default(uuid())
  title             String
  slug              String            @unique
  assetType         AssetType
  rightsHolderOrgId String
  rightsHolder      Organization      @relation("RightsHolder", fields: [rightsHolderOrgId], references: [id])
  metadata          Json?
  /// Имя файла постера на диске (uploads/catalog/{id}/{posterFileName})
  posterFileName    String?           @db.VarChar(512)
  status            CatalogItemStatus @default(draft)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  licenseTerms LicenseTerm[]
  deals        DealCatalogItem[]
}

model LicenseTerm {
  id                  String      @id @default(uuid())
  catalogItemId       String
  catalogItem         CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  territoryCode       String
  startAt             DateTime?
  endAt               DateTime?
  durationMonths      Int?
  exclusivity         Exclusivity
  platforms           Platform[]
  sublicensingAllowed Boolean     @default(false)
  languageRights      String[]
}

model Deal {
  id                 String    @id @default(uuid())
  title              String
  kind               DealKind  @default(sale)
  stage              DealStage
  /// Скрыта из активной воронки; права архивных сделок не блокируют новые продажи.
  archived           Boolean   @default(false)
  ownerUserId        String
  owner              User      @relation("DealOwner", fields: [ownerUserId], references: [id])
  buyerOrgId         String
  buyer              Organization @relation("BuyerOrg", fields: [buyerOrgId], references: [id])
  currency           String    @db.VarChar(3)
  expectedCloseAt    DateTime?
  actualCloseAt      DateTime?
  commercialSnapshot Json?
  /// Вложения по слотам (устав, цепочка прав и т.д.): ключ слота → { storedFileName, originalName, ... }
  dealDocuments      Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  catalogItems DealCatalogItem[]
  contracts    Contract[]
  payments     Payment[]
  activities   DealActivity[]
}

model DealCatalogItem {
  dealId           String
  catalogItemId    String
  deal             Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  catalogItem      CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  /// Выбранные в сделке права (территории, срок, платформы, формат лицензии) для валидации и контракта
  rightsSelection  Json?

  @@id([dealId, catalogItemId])
}

model DealActivity {
  id        String           @id @default(uuid())
  dealId    String
  deal      Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  kind      DealActivityKind
  message   String
  metadata  Json?
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())
}

model Contract {
  id           String         @id @default(uuid())
  dealId       String
  deal         Deal           @relation(fields: [dealId], references: [id])
  number       String
  status       ContractStatus
  territory    String
  termEndAt    DateTime
  amount       Decimal        @db.Decimal(18, 2)
  currency     String         @db.VarChar(3)
  fxRateFixed  Decimal?       @db.Decimal(18, 8)
  fxRateSource String?
  fxLockedAt   DateTime?
  rightsPayload Json?
  templateId   String?
  signingDueAt DateTime?
  /// Хеш/снимок полей сделки на момент генерации (для предупреждения о расхождении)
  dealSnapshotFingerprint String?
  archived     Boolean        @default(false)
  /// Подписанный/прикреплённый файл из кабинета клиента (иначе оформлен в CRM)
  clientCabinetSigned Boolean   @default(false)
  cabinetSignedAt     DateTime?
  /// Исходный контракт из CRM, если в кабинете прикрепили подпись к выпущенному документу
  sourceContractId    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  versions     ContractVersion[]
  payments     Payment[]
  royaltyLines RoyaltyLine[]
  payouts      Payout[]
}

model ContractVersion {
  id         String    @id @default(uuid())
  contractId String
  contract   Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  version    Int
  storageKey String
  sha256     String
  templateId String
  createdAt  DateTime  @default(now())
  signedAt   DateTime?

  @@unique([contractId, version])
}

model Payment {
  id String    @id @default(uuid())
  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id])
  dealId     String?
  deal       Deal?     @relation(fields: [dealId], references: [id])
  direction  PaymentDirection
  /// Сумма платежа (как в договорённости: обычно gross к удержанию)
  amount     Decimal          @db.Decimal(18, 2)
  currency   String           @db.VarChar(3)
  /// Удержание с этого платежа (расчёт по TaxProfile покупателя)
  withholdingTaxAmount Decimal? @db.Decimal(18, 2)
  netAmount            Decimal? @db.Decimal(18, 2)
  dueAt      DateTime?
  paidAt     DateTime?
  status     PaymentStatus    @default(pending)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
}

model RoyaltyLine {
  id                 String       @id @default(uuid())
  contractId         String
  contract           Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  rightsHolderOrgId  String
  rightsHolder       Organization @relation(fields: [rightsHolderOrgId], references: [id])
  model              RoyaltyModel
  percent            Decimal?     @db.Decimal(9, 4)
  fixedAmount        Decimal?     @db.Decimal(18, 2)
  base               RoyaltyBase
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  payouts Payout[]
}

model TaxProfile {
  id                          String       @id @default(uuid())
  organizationId              String
  organization                Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jurisdiction                String
  isTaxResidentInPayerCountry Boolean      @default(false)
  dtCertificatePresent        Boolean      @default(false)
  withholdingRateOverride     Decimal?     @db.Decimal(9, 4)
  residencyCertificateKey     String?
  validUntil                  DateTime?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt

  @@unique([organizationId, jurisdiction])
}

model Payout {
  id                    String       @id @default(uuid())
  royaltyLineId         String
  royaltyLine           RoyaltyLine  @relation(fields: [royaltyLineId], references: [id])
  contractId            String
  contract              Contract     @relation(fields: [contractId], references: [id])
  rightsHolderOrgId     String
  rightsHolder          Organization @relation(fields: [rightsHolderOrgId], references: [id])
  amountGross           Decimal      @db.Decimal(18, 2)
  withholdingTaxAmount Decimal     @db.Decimal(18, 2)
  amountNet             Decimal      @db.Decimal(18, 2)
  currency              String       @db.VarChar(3)
  taxProfileSnapshotId  String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model Task {
  id                String @id @default(uuid())
  assigneeId        String
  assignee          User         @relation(fields: [assigneeId], references: [id])
  dueAt             DateTime
  type              TaskType
  status            TaskStatus   @default(todo)
  priority          TaskPriority @default(medium)
  linkedEntityType  String
  linkedEntityId    String
  title             String?
  description       String?      @db.Text
  archived          Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  comments TaskComment[]
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
}

/// Коммерческое предложение (оффер) — PDF в uploads по storageKey
model CommercialOffer {
  id         String   @id @default(uuid())
  title      String
  payload    Json
  storageKey String
  archived   Boolean  @default(false)
  /// Подписанный экземпляр, загруженный из кабинета клиента (иначе сгенерирован в CRM)
  clientSigned  Boolean   @default(false)
  signedAt      DateTime?
  /// Исходный оффер из CRM, если подпись прикреплена к выпущенному документу
  sourceOfferId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
