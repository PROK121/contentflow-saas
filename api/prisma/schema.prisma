// ContentFlow — ядро БД (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationType {
  client
  rights_holder
  internal
}

enum UserRole {
  admin
  manager
  rights_owner
  client
}

enum DealStage {
  lead
  negotiation
  contract
  paid
}

/// Продажа — лицензирование контента контрагенту (клиент). Покупка — приобретение прав у контрагента.
enum DealKind {
  sale
  purchase
}

enum AssetType {
  video
  series
  animated_series
  animated_film
  anime_series
  anime_film
  concert_show
}

enum CatalogItemStatus {
  draft
  active
  archived
}

enum Platform {
  TV
  OTT
  Web
  YouTube
  VOD
  ShipIfec
  PublicRights
}

enum Exclusivity {
  exclusive
  co_exclusive
  non_exclusive
  sole
}

enum ContractStatus {
  draft
  sent
  signed
  expired
}

enum PaymentDirection {
  inbound
  outbound
}

enum PaymentStatus {
  pending
  partially_paid
  paid
  overdue
  cancelled
}

enum RoyaltyModel {
  fixed
  percent
}

enum RoyaltyBase {
  gross
  net
  collections
}

enum TaskType {
  contract_expiry
  payment_due
  renewal
  custom
}

enum TaskStatus {
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  low
  medium
  high
}

enum DealActivityKind {
  comment
  system
  file
}

/// Уровень видимости финансовой информации для пользователей-правообладателей
/// в кабинете /holder/*. Применяется только к организациям типа rights_holder.
///
/// `limited` — показываем только: статусы сделок (без сумм), даты, тип контракта,
/// факт получения выплаты (да/нет/дата), но не сумму. Используется по умолчанию,
/// если в договоре с правообладателем нет согласованного раскрытия деталей.
///
/// `full` — кроме перечисленного выше показываем суммы выплат, сумму контракта,
/// валюту, разбивку по платежам. Включается менеджером вручную в карточке
/// организации (требует подписанного приложения).
enum HolderFinanceVisibility {
  limited
  full
}

model Organization {
  id         String           @id @default(uuid())
  legalName  String
  country    String
  taxId      String?
  isResident Boolean          @default(false)
  type       OrganizationType
  metadata   Json?
  /// Флаг видимости финансов в кабинете правообладателя. По умолчанию
  /// `limited` — не показываем суммы. Применяется только к rights_holder.
  holderFinanceVisibility HolderFinanceVisibility @default(limited)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  users                User[]
  catalogItemsAsHolder CatalogItem[] @relation("RightsHolder")
  dealsAsBuyer         Deal[]        @relation("BuyerOrg")
  taxProfiles          TaxProfile[]
  royaltyLines         RoyaltyLine[]
  payouts              Payout[]
  holderInvites        HolderInvite[]
  materialRequests     MaterialRequest[]
}

model User {
  id             String    @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  email          String    @unique
  /// Bcrypt-хеш пароля; null — вход по паролю недоступен.
  passwordHash   String?
  displayName    String?
  role           UserRole
  locale         String    @default("ru")
  /// Произвольные данные пользователя (телефон, флаги уведомлений и т.п.)
  metadata       Json?
  /// Когда был выслан инвайт (заполняется при создании учётки приглашением)
  invitedAt          DateTime?
  /// Кто пригласил (менеджер/админ, для аудита)
  invitedByUserId    String?
  /// Когда пользователь принял условия (NDA / правила использования платформы)
  acceptedTermsAt    DateTime?
  /// Версия принятых условий — на случай обновлений требуется повторное согласие
  acceptedTermsVer   String?
  /// Последний успешный вход — для аналитики и подозрительной активности
  lastLoginAt        DateTime?
  /// IP последнего входа (для аудита)
  lastLoginIp        String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  ownedDeals       Deal[]         @relation("DealOwner")
  tasks            Task[]
  taskComments     TaskComment[]
  dealActivities   DealActivity[]
  invitesSent      HolderInvite[] @relation("InviteCreator")
  holderAuditLogs  HolderAuditLog[]
  materialReviews  MaterialUpload[] @relation("MaterialReviewer")

  @@index([organizationId])
  @@index([role])
}

/// Инвайт-токен для приглашения правообладателя (или клиента) в кабинет.
/// Сам токен в БД не хранится — только sha256-хеш. Токен живёт в email-ссылке.
model HolderInvite {
  id              String   @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Email, на который отправлен инвайт (нормализованный, lowercase).
  email           String
  /// SHA-256 от исходного токена, который отправили в письме.
  tokenHash       String   @unique
  /// Создавший пользователь (менеджер/админ).
  invitedByUserId String
  invitedBy       User     @relation("InviteCreator", fields: [invitedByUserId], references: [id])
  /// До какого времени инвайт валиден (рекомендуем 7 дней).
  expiresAt       DateTime
  /// Когда инвайт принят и создан/активирован пользователь. null — ещё не принят.
  consumedAt      DateTime?
  /// Какой User создан/привязан в результате принятия инвайта.
  consumedByUserId String?
  /// Опциональное приглашение-сообщение от менеджера.
  note            String?
  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([email])
  @@index([expiresAt])
}

/// Аудит критичных действий правообладателя в кабинете.
/// Используется для юридических/security-разборов — кто/когда/что/откуда.
model HolderAuditLog {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  organizationId String
  /// Машиночитаемое имя действия (login, view_deal, download_contract, sign_contract, upload_material, view_payout и т.д.)
  action         String
  /// Какая сущность затронута (Deal, Contract, CatalogItem, Payout, MaterialRequest)
  entityType     String?
  entityId       String?
  ip             String?
  userAgent      String?
  /// Дополнительные машинные данные (например, slot для upload).
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

/// Запрос на материалы по тайтлу: «нужны мастер, постер, субтитры RU/KZ к 30 мая».
/// Создаёт менеджер, выполняет правообладатель в кабинете.
enum MaterialRequestStatus {
  pending
  partial
  complete
  rejected
  cancelled
}

model MaterialRequest {
  id              String                 @id @default(uuid())
  catalogItemId   String
  catalogItem     CatalogItem            @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  /// Правообладатель, кому предъявлен запрос (для скоупа в кабинете).
  organizationId  String
  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Список требуемых слотов: master_video, poster, subtitles_ru и т.д.
  requestedSlots  String[]
  status          MaterialRequestStatus  @default(pending)
  dueAt           DateTime?
  /// Свободный текст: пояснение менеджера правообладателю.
  note            String?
  createdByUserId String
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  uploads MaterialUpload[]

  @@index([catalogItemId])
  @@index([organizationId, status])
}

enum MaterialReviewStatus {
  pending
  approved
  rejected
}

model MaterialUpload {
  id              String              @id @default(uuid())
  requestId       String
  request         MaterialRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  /// Один из requestedSlots (master_video, poster, ...).
  slot            String
  /// Имя файла на диске (uploads/materials/{requestId}/{storedFileName}).
  storedFileName  String              @db.VarChar(512)
  originalName    String              @db.VarChar(512)
  size            BigInt
  mimeType        String?
  reviewStatus    MaterialReviewStatus @default(pending)
  reviewerComment String?             @db.Text
  reviewedByUserId String?
  reviewedBy      User?               @relation("MaterialReviewer", fields: [reviewedByUserId], references: [id])
  reviewedAt      DateTime?
  uploadedAt      DateTime            @default(now())

  @@index([requestId])
  @@index([slot])
  @@index([reviewStatus])
}

model CatalogItem {
  id                String            @id @default(uuid())
  title             String
  slug              String            @unique
  assetType         AssetType
  rightsHolderOrgId String
  rightsHolder      Organization      @relation("RightsHolder", fields: [rightsHolderOrgId], references: [id])
  metadata          Json?
  /// Имя файла постера на диске (uploads/catalog/{id}/{posterFileName})
  posterFileName    String?           @db.VarChar(512)
  status            CatalogItemStatus @default(draft)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  licenseTerms     LicenseTerm[]
  deals            DealCatalogItem[]
  materialRequests MaterialRequest[]
}

model LicenseTerm {
  id                  String      @id @default(uuid())
  catalogItemId       String
  catalogItem         CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  territoryCode       String
  startAt             DateTime?
  endAt               DateTime?
  durationMonths      Int?
  exclusivity         Exclusivity
  platforms           Platform[]
  sublicensingAllowed Boolean     @default(false)
  languageRights      String[]
}

model Deal {
  id                 String    @id @default(uuid())
  title              String
  kind               DealKind  @default(sale)
  stage              DealStage
  /// Скрыта из активной воронки; права архивных сделок не блокируют новые продажи.
  archived           Boolean   @default(false)
  ownerUserId        String
  owner              User      @relation("DealOwner", fields: [ownerUserId], references: [id])
  buyerOrgId         String
  buyer              Organization @relation("BuyerOrg", fields: [buyerOrgId], references: [id])
  currency           String    @db.VarChar(3)
  expectedCloseAt    DateTime?
  actualCloseAt      DateTime?
  commercialSnapshot Json?
  /// Вложения по слотам (устав, цепочка прав и т.д.): ключ слота → { storedFileName, originalName, ... }
  dealDocuments      Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  catalogItems DealCatalogItem[]
  contracts    Contract[]
  payments     Payment[]
  activities   DealActivity[]

  @@index([ownerUserId])
  @@index([buyerOrgId])
  @@index([stage])
  @@index([archived])
}

model DealCatalogItem {
  dealId           String
  catalogItemId    String
  deal             Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  catalogItem      CatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  /// Выбранные в сделке права (территории, срок, платформы, формат лицензии) для валидации и контракта
  rightsSelection  Json?

  @@id([dealId, catalogItemId])
}

model DealActivity {
  id        String           @id @default(uuid())
  dealId    String
  deal      Deal             @relation(fields: [dealId], references: [id], onDelete: Cascade)
  kind      DealActivityKind
  message   String
  metadata  Json?
  userId    String?
  user      User?            @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())

  @@index([dealId, createdAt])
}

model Contract {
  id           String         @id @default(uuid())
  dealId       String
  deal         Deal           @relation(fields: [dealId], references: [id])
  number       String
  status       ContractStatus
  territory    String
  termEndAt    DateTime
  amount       Decimal        @db.Decimal(18, 2)
  currency     String         @db.VarChar(3)
  fxRateFixed  Decimal?       @db.Decimal(18, 8)
  fxRateSource String?
  fxLockedAt   DateTime?
  rightsPayload Json?
  templateId   String?
  signingDueAt DateTime?
  /// Хеш/снимок полей сделки на момент генерации (для предупреждения о расхождении)
  dealSnapshotFingerprint String?
  archived     Boolean        @default(false)
  /// Подписанный/прикреплённый файл из кабинета клиента (иначе оформлен в CRM)
  clientCabinetSigned Boolean   @default(false)
  cabinetSignedAt     DateTime?
  /// Исходный контракт из CRM, если в кабинете прикрепили подпись к выпущенному документу
  sourceContractId    String?

  // -------------------------------------------------------------------------
  // Click-sign правообладателя из кабинета /holder/contracts/:id.
  // Это юридически значимое действие: фиксируем кто, когда, с какого IP/UA
  // и какую версию документа подписал. Меняется только из /v1/holder/...
  // -------------------------------------------------------------------------
  /// Кто подписал из кабинета правообладателя (User.id, role=rights_owner).
  holderSignedByUserId String?
  /// Когда подписан в кабинете правообладателя.
  holderSignedAt       DateTime?
  /// IP пользователя, выполнившего click-sign.
  holderSignedIp       String?
  /// User-Agent пользователя, выполнившего click-sign.
  holderSignedUserAgent String?
  /// Версия `ContractVersion.version`, на которую правообладатель кликнул.
  holderSignedVersion  Int?
  /// sha256 содержимого PDF на момент подписи (берём из ContractVersion.sha256).
  /// Если в дальнейшем содержимое изменили — подпись не действительна.
  holderSignedHash     String?
  /// Версия пользовательского соглашения о подписании.
  holderSignedTermsVer String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  versions     ContractVersion[]
  payments     Payment[]
  royaltyLines RoyaltyLine[]
  payouts      Payout[]
}

model ContractVersion {
  id         String    @id @default(uuid())
  contractId String
  contract   Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  version    Int
  storageKey String
  sha256     String
  templateId String
  createdAt  DateTime  @default(now())
  signedAt   DateTime?

  @@unique([contractId, version])
}

model Payment {
  id String    @id @default(uuid())
  contractId String?
  contract   Contract? @relation(fields: [contractId], references: [id])
  dealId     String?
  deal       Deal?     @relation(fields: [dealId], references: [id])
  direction  PaymentDirection
  /// Сумма платежа (как в договорённости: обычно gross к удержанию)
  amount     Decimal          @db.Decimal(18, 2)
  currency   String           @db.VarChar(3)
  /// Удержание с этого платежа (расчёт по TaxProfile покупателя)
  withholdingTaxAmount Decimal? @db.Decimal(18, 2)
  netAmount            Decimal? @db.Decimal(18, 2)
  dueAt      DateTime?
  paidAt     DateTime?
  status     PaymentStatus    @default(pending)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([dealId])
  @@index([contractId])
  @@index([status])
}

model RoyaltyLine {
  id                 String       @id @default(uuid())
  contractId         String
  contract           Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  rightsHolderOrgId  String
  rightsHolder       Organization @relation(fields: [rightsHolderOrgId], references: [id])
  model              RoyaltyModel
  percent            Decimal?     @db.Decimal(9, 4)
  fixedAmount        Decimal?     @db.Decimal(18, 2)
  base               RoyaltyBase
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  payouts Payout[]
}

model TaxProfile {
  id                          String       @id @default(uuid())
  organizationId              String
  organization                Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jurisdiction                String
  isTaxResidentInPayerCountry Boolean      @default(false)
  dtCertificatePresent        Boolean      @default(false)
  withholdingRateOverride     Decimal?     @db.Decimal(9, 4)
  residencyCertificateKey     String?
  validUntil                  DateTime?
  createdAt                   DateTime     @default(now())
  updatedAt                   DateTime     @updatedAt

  @@unique([organizationId, jurisdiction])
}

model Payout {
  id                    String       @id @default(uuid())
  royaltyLineId         String
  royaltyLine           RoyaltyLine  @relation(fields: [royaltyLineId], references: [id])
  contractId            String
  contract              Contract     @relation(fields: [contractId], references: [id])
  rightsHolderOrgId     String
  rightsHolder          Organization @relation(fields: [rightsHolderOrgId], references: [id])
  amountGross           Decimal      @db.Decimal(18, 2)
  withholdingTaxAmount Decimal     @db.Decimal(18, 2)
  amountNet             Decimal      @db.Decimal(18, 2)
  currency              String       @db.VarChar(3)
  taxProfileSnapshotId  String?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
}

model Task {
  id                String @id @default(uuid())
  assigneeId        String
  assignee          User         @relation(fields: [assigneeId], references: [id])
  dueAt             DateTime
  type              TaskType
  status            TaskStatus   @default(todo)
  priority          TaskPriority @default(medium)
  linkedEntityType  String
  linkedEntityId    String
  title             String?
  description       String?      @db.Text
  archived          Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  comments TaskComment[]

  @@index([assigneeId])
  @@index([status])
  @@index([dueAt])
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([taskId, createdAt])
}

/// Коммерческое предложение (оффер) — PDF в uploads по storageKey
model CommercialOffer {
  id         String   @id @default(uuid())
  title      String
  payload    Json
  storageKey String
  archived   Boolean  @default(false)
  /// Подписанный экземпляр, загруженный из кабинета клиента (иначе сгенерирован в CRM)
  clientSigned  Boolean   @default(false)
  signedAt      DateTime?
  /// Исходный оффер из CRM, если подпись прикреплена к выпущенному документу
  sourceOfferId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
