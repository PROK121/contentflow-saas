# --- Homebrew PostgreSQL (macOS): подставь своего пользователя: whoami
DATABASE_URL="postgresql://admin@localhost:5432/contentflow?schema=public"

# --- Docker (docker compose в корне репо): пользователь contentflow
# DATABASE_URL="postgresql://contentflow:contentflow@localhost:5432/contentflow?schema=public"

PORT=3000
WEB_ORIGIN=http://localhost:3020

# JWT (должен совпадать с JWT_SECRET в web/.env для middleware).
# В проде ОБЯЗАТЕЛЬНО ≥48 символов случайной строки. Сгенерировать:
#   openssl rand -hex 48
# При смене секрета все ранее выпущенные JWT инвалидируются (это полный
# logout-all для всех пользователей системы).
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-48

# Офферы в PDF: путь к soffice (LibreOffice). macOS по умолчанию: /Applications/LibreOffice.app/Contents/MacOS/soffice
# LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice

# -----------------------------------------------------------------------------
# SMTP — отправка писем (приглашения, magic-link, уведомления о материалах
# и контрактах). Если SMTP_URL не задан — письма не отправляются, а только
# логируются в stdout (CONSOLE-режим). Удобно для dev.
# -----------------------------------------------------------------------------

# Google Workspace SMTP Relay (рекомендуется):
#   smtp://info%40growixcontent.com:APP_PASSWORD@smtp-relay.gmail.com:587?secure=false&requireTLS=true
# Требует включённого SMTP Relay в Google Admin Console
# (Apps -> Gmail -> Routing -> SMTP relay service).
#
# Альтернатива — обычный smtp.gmail.com (без relay, mailbox жёстко = логин):
#   smtps://info%40growixcontent.com:APP_PASSWORD@smtp.gmail.com:465
#
# Спецсимволы в логине/пароле кодируем %XX (`@` → `%40`, `:` → `%3A`).
# SMTP_URL=

# Email-адрес служебного отправителя (envelope-from по умолчанию).
# В relay-режиме перезаписывается на email инициирующего менеджера для
# конкретного письма (см. EMAIL_SENDER_OVERRIDE).
# EMAIL_FROM="Growix Content <info@growixcontent.com>"

# Display-name бренда. Подставляется, когда у конкретного письма нет
# fromName инициирующего менеджера.
# EMAIL_FROM_NAME="Growix Content"

# Включает relay-режим: для каждого письма envelope-from подменяется на email
# менеджера/правообладателя, инициировавшего действие. Получатель видит в
# поле From ровно его адрес. Работает только с SMTP-сервером, разрешающим
# отправку от любого адреса в домене (Google Workspace SMTP Relay).
# По умолчанию выключен — письма уходят с EMAIL_FROM, а email инициатора
# попадает в Reply-To.
# EMAIL_SENDER_OVERRIDE=true

# Через запятую — список доменов, для которых разрешён relay. Если адрес
# инициатора не попадает сюда (например, правообладатель с gmail.com) —
# override игнорируется, и письмо уходит с EMAIL_FROM.
# По умолчанию включается домен из EMAIL_FROM, дополнительные — здесь.
# EMAIL_RELAY_DOMAINS=growixcontent.com
