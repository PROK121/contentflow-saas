# --- Homebrew PostgreSQL (macOS): подставь своего пользователя: whoami
DATABASE_URL="postgresql://admin@localhost:5432/contentflow?schema=public"

# --- Docker (docker compose в корне репо): пользователь contentflow
# DATABASE_URL="postgresql://contentflow:contentflow@localhost:5432/contentflow?schema=public"

PORT=3000
WEB_ORIGIN=http://localhost:3020

# JWT (должен совпадать с JWT_SECRET в web/.env для middleware)
JWT_SECRET=change-me-in-production-use-long-random-string

# Офферы в PDF: путь к soffice (LibreOffice). macOS по умолчанию: /Applications/LibreOffice.app/Contents/MacOS/soffice
# LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice
